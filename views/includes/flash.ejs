<% if(typeof success !== "undefined" && success.length){ %>
  <div class="alert alert-primary alert-dismissible fade show col-6 offset-3">
    <%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<% if(typeof error !== "undefined" && error.length){ %>
  <div class="alert alert-danger alert-dismissible fade show col-6 offset-3">
    <%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>