<%layout('/layout/boiler.ejs')%>
<script>
  const coords = <%- JSON.stringify(listing.geometry.coordinates) %>;
  
  if(!coords.length){
  console.log("No coordinates found");
}


</script>
  <body>
    <div class="row col-8 offset-2">
      <h3 style="text-align: center;">
        <%=listing.title%>
      </h3>
      <hr>
      <div class="card">
        <img src="<%=listing.image%>" class="card-img-top info-img" alt="Image_info">
        <div class="card-body">
          <p class="card-text"><b>
              <%= listing.owner ? listing.owner.username : "Unknown User" %>
            </b></p>
          <p class="card-text">
            <%=listing.description%>
          </p>
          <p class="card-text">&#8377;<%= listing.price ? listing.price.toLocaleString('en-IN') : "0" %>
          </p>
          <p class="card-text">
            <%=listing.location%>
          </p>
          <p class="card-text">
            <%=listing.country%>
          </p>
        </div>
      </div>

      <% if(UserInfo && listing.owner._id.equals(UserInfo._id)){%>
        <div class="row col-sm-4">
          <form action="/listning/<%=listing._id%>/edit">
            <button class="btn  btn-primary">Edit this list</button>
          </form>
        </div>
        <div class="row col-sm-4">
          <form method="post" action="/listning/<%=listing._id%>?_method=DELETE"><button class="btn  btn-danger">Delete
              this list</button></form>
        </div>
        <%}%>


    </div>


    <!-- For Reviews -->
    <div class="col-8 offset-2">
      <hr>
      <%if(UserInfo){%>
        <h3>Review</h3>
        <form action="/listning/<%=listing._id%>/reviews" method="post" class="needs-validation" novalidate>

          <!-- for rating -->


          <label for="rating" class="form-label">Rating</label>
          <fieldset class="starability-slot">
            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked
              aria-label="No rating." />
            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
            <label for="first-rate1" title="Terrible">1 star</label>
            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
            <label for="first-rate2" title="Not good">2 stars</label>
            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
            <label for="first-rate3" title="Average">3 stars</label>
            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
            <label for="first-rate4" title="Very good">4 stars</label>
            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
            <label for="first-rate5" title="Amazing">5 stars</label>
          </fieldset>


          <!-- comment -->
          <div>
            <label for="comment">Comment</label>
            <textarea name="review[comment]" rows="8" cols="100" class="form-control" required></textarea>
            <div class="invalid-feedback">
              Please Fill Comment..
            </div>

          </div>
          <button class="btn btn-outline-dark">Submit</button>
          <%}%>
        </form>

        <p> <b>All Reviews</b></p>
        <div class="row">
          <%for( review of listing.reviews){%>
            <div class="col-6">
              <div class="card  cd-re mb-3">
                <div class="card-body ">
                  <p class="body-text ">
                    <%=review.author.username%>
                  </p>
                  <p class="card-text">
                    <%=review.comment%>
                  </p>
                 
                  <p class="starability-result card-text" data-rating="<%=review.rating%>"></p>
                  <form method="post" action="/listning/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
                    <button class="btn btn-dark">delete</button>
                  </form>

                </div>
              </div>
            </div>
            <%}%>


        </div>

        <!-- for Map -->
        <h3>Location Map</h3>
        
    <div id="map"></div>

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<script>

const blackIcon = L.icon({
 iconUrl:'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-black.png',
 shadowUrl:'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',
 iconSize:[25,41],
 iconAnchor:[12,41],
 popupAnchor:[1,-34],
 shadowSize:[41,41]
});

const map = L.map('map').setView(
  [coords[1], coords[0]], 13
);

L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
 attribution: '&copy; OpenStreetMap contributors'
}).addTo(map);

L.marker([coords[1], coords[0]],{icon:blackIcon}).addTo(map)
.bindPopup("<%= listing.location %>")
.openPopup();



</script>
<br>
    </div>
    
  </body>